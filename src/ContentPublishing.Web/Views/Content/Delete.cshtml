@model ContentPublishing.Web.ViewModels.ContentListItemViewModel
@{
    ViewBag.Title = "Archive Content";
}

<section class="mx-auto max-w-xl rounded-lg bg-white p-6 shadow">
    <h2 class="mb-2 text-2xl font-bold">Archive Content</h2>
    <p class="text-slate-700">Are you sure you want to archive <span
        class="font-semibold">@Html.Raw(Model.Title)</span>?</p>
        <p class="mt-2 text-sm text-slate-500">Archived content remains queryable but cannot be edited.</p>

        @using (Html.BeginForm("Delete", "Content", FormMethod.Post, new { @class = "mt-4 flex gap-2" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.ContentId" />
            <button type="submit" class="rounded bg-red-700 px-4 py-2 text-white">Archive</button>
            <a href="@Url.Action("Details", "Content", new { id = Model.ContentId })"
               class="rounded border border-slate-300 px-4 py-2">Cancel</a>
        }
    </section>
