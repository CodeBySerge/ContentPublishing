@model IList<ContentPublishing.Web.ViewModels.ContentListItemViewModel>
@{
    ViewBag.Title = "My Content";
}

<section class="space-y-4">
    <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold">My Content</h2>
        <a href="@Url.Action("Create", "Content")" class="rounded bg-slate-900 px-4 py-2 text-white">New Content</a>
    </div>

    <div class="overflow-hidden rounded-lg bg-white shadow">
        <table class="min-w-full text-sm">
            <thead class="bg-slate-100 text-left text-slate-600">
                <tr>
                    <th class="px-4 py-3">Title</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3">Chapters</th>
                    <th class="px-4 py-3">Updated</th>
                    <th class="px-4 py-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-4 py-6 text-center text-slate-500">No content yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="border-t border-slate-100">
                            <td class="px-4 py-3 font-medium">@Html.Raw(item.Title)</td>
                            <td class="px-4 py-3">@item.Status</td>
                            <td class="px-4 py-3">@item.ChapterCount</td>
                            <td class="px-4 py-3">@item.LastModifiedDate.ToString("u")</td>
                            <td class="px-4 py-3">
                                <a class="text-slate-900 underline"
                                   href="@Url.Action("Details", "Content", new { id = item.ContentId })">Open</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>
