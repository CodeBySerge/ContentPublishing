@model IList<ContentPublishing.Web.ViewModels.ContentListItemViewModel>
@{
    ViewBag.Title = "Edit Content";
}

<section class="space-y-4">
    <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold">Edit Content</h2>
        <span class="text-sm text-slate-600">Total Chapters: @Model.Count</span>
    </div>

    <div class="overflow-hidden rounded-lg bg-white p-3 shadow">
        <table id="contentTable" class="min-w-full text-sm">
            <thead class="bg-slate-100 text-left text-slate-600">
                <tr>
                    <th class="px-4 py-3">Content ID</th>
                    <th class="px-4 py-3">Chapter</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3">Updated</th>
                    <th class="px-4 py-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="px-4 py-6 text-center text-slate-500">No handbook chapters found.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="border-t border-slate-100">
                            <td class="px-4 py-3">@item.ContentNumber</td>
                            <td class="px-4 py-3 font-medium">@Html.Raw(item.Title)</td>
                            <td class="px-4 py-3">@item.Status</td>
                            <td class="px-4 py-3">@item.LastModifiedDate.ToString("u")</td>
                            <td class="px-4 py-3">
                                @if (item.PrimaryChapterId.HasValue)
                                {
                                    <a class="text-slate-900 underline"
                                       href="@Url.Action("Edit", "Chapter", new { id = item.PrimaryChapterId.Value })">Open
                                        Chapter</a>
                                    }
                                else
                                    {
                                        <a class="text-slate-900 underline"
                                           href="@Url.Action("Details", "Content", new { id = item.ContentId })">Open</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    @section scripts {
        <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />
        <script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
        <script>
            $(function () {
            $("#contentTable").DataTable({
            pageLength: 10,
            lengthChange: false,
            ordering: true,
            order: [[0, "asc"]],
            columnDefs: [
            { orderable: false, targets: 4 }
            ],
            pagingType: "simple_numbers",
            language: {
            paginate: {
            previous: "Prev",
            next: "Next"
            }
            }
            });
            });
        </script>
    }
