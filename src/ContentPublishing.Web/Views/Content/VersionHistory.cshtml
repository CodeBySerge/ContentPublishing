@model IList<ContentPublishing.Web.Models.ContentVersionEntity>
@{
    ViewBag.Title = "Version History";
}

<section class="space-y-4">
    <div class="flex items-center justify-between">
        <h2 class="text-2xl font-bold">Version History</h2>
        <a href="@Url.Action("Details", "Content", new { id = ViewBag.ContentId })" class="rounded border border-slate-300 px-3 py-2">Back to Content</a>
    </div>

    <div class="space-y-4">
        @if (!Model.Any())
        {
            <div class="rounded-lg bg-white p-6 text-slate-500 shadow">No versions recorded yet.</div>
        }
        else
        {
            foreach (var version in Model)
            {
                <article class="rounded-lg bg-white p-6 shadow">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <h3 class="text-lg font-semibold">Version @version.VersionNumber</h3>
                            <p class="text-sm text-slate-500">@version.Action on @version.CreatedDate.ToString("u")</p>
                        </div>
                        <p class="text-sm text-slate-500">@version.Notes</p>
                    </div>
                    <pre class="mt-4 overflow-x-auto rounded bg-slate-950 p-4 text-xs text-slate-100">@version.SnapshotJson</pre>
                </article>
            }
        }
    </div>
</section>
