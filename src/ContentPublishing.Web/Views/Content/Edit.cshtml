@model ContentPublishing.Web.ViewModels.ContentEditViewModel
@{
    ViewBag.Title = "Edit Content";
}

<section class="mx-auto max-w-2xl rounded-lg bg-white p-6 shadow">
    <h2 class="mb-4 text-2xl font-bold">Edit Content</h2>

    @using (Html.BeginForm("Edit", "Content", FormMethod.Post, new
    {
        id = "contentForm",
        @class = "space-y-4"
    }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.ContentId)
        @Html.ValidationSummary(true, "", new { @class = "text-sm text-red-600" })

        <div>
            @Html.LabelFor(m => m.Title, new { @class = "mb-1 block text-sm font-medium" })
            @Html.TextBoxFor(m => m.Title, new
            {
                @class = "w-full rounded-md border border-slate-300 px-3 py-2",
                maxlength =
 "250"
            })
            @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-xs text-red-600" })
        </div>

        <div>
            @Html.LabelFor(m => m.Description, new { @class = "mb-1 block text-sm font-medium" })
            @Html.TextAreaFor(m => m.Description, 10, 40, new { @class = "w-full rounded-md border border-slate-300 px-3 py-2", id = "descriptionEditor" })
            @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-xs text-red-600" })
        </div>

        <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-white">Save Changes</button>
    }
</section>

@section scripts {
    <script src="https://cdn.tiny.cloud/1/zr0s1ze2y3f4ufpcb1gn892mftbi3j04oxcc3ii21s0pgaoe/tinymce/6/tinymce.min.js"
            referrerpolicy="origin"></script>
    <script>
        $(function () {
            tinymce.init({
                selector: "#descriptionEditor",
                menubar: "file edit view insert format tools table help",
                plugins: "lists link image table code fullscreen wordcount preview searchreplace visualblocks",
                toolbar: "undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | forecolor backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | link image table | removeformat code fullscreen preview",
                height: 380,
                branding: false,
                promotion: false,
                browser_spellcheck: true,
                convert_urls: false
            });

            $("#contentForm").on("submit", function () {
                tinymce.triggerSave();
            });

            $("#contentForm").validate({
                rules: {
                    Title: { required: true, maxlength: 250 }
                }
            });

        });
    </script>
}
