@model ContentPublishing.Web.ViewModels.ChapterEditViewModel
@using System.Collections.Generic
@using System.Web.Mvc
@{
    ViewBag.Title = "Edit Chapter";
    var reviewerOptions = ViewBag.ReviewerOptions as IList<SelectListItem> ?? new List<SelectListItem>();
}

<section class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-[860px] rounded-lg bg-white p-8 shadow">
    <h2 class="mb-4 text-2xl font-bold">Edit Chapter Draft</h2>
    <p class="mb-3 text-sm text-slate-600">Content ID: @Model.ContentNumber | Chapter ID: @(Model.ChapterNumber.HasValue ? Model.ChapterNumber.Value.ToString() : "New")</p>

    <div class="mb-5 rounded border border-slate-200 bg-slate-50 p-4">
        <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-slate-600">Current Chapter Content</h3>
        <div class="prose prose-slate max-w-none text-slate-700 prose-headings:font-semibold prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl prose-p:leading-7">@Html.Raw(Model.ChapterBody)</div>
    </div>

    @using (Html.BeginForm("Edit", "Chapter", FormMethod.Post, new { id = "chapterForm", @class = "space-y-4" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.ChapterId)
        @Html.HiddenFor(m => m.ContentId)
        @Html.HiddenFor(m => m.ReviewerIds, new { id = "reviewerIds" })
        @Html.ValidationSummary(true, "", new { @class = "text-sm text-red-600" })

        <div>
            @Html.LabelFor(m => m.ChapterTitle, new { @class = "mb-1 block text-sm font-medium" })
            @Html.TextBoxFor(m => m.ChapterTitle, new
            {
                @class = "w-full rounded-md border border-slate-300 px-3 py-2",
                maxlength = "250"
            })
            @Html.ValidationMessageFor(m => m.ChapterTitle, "", new { @class = "text-xs text-red-600" })
        </div>

        <div>
            @Html.LabelFor(m => m.ChapterBody, new { @class = "mb-1 block text-sm font-medium" })
            @Html.TextAreaFor(m => m.ChapterBody, 14, 60, new { @class = "w-full rounded-md border border-slate-300 px-3 py-2", id = "chapterBodyEditor" })
            @Html.ValidationMessageFor(m => m.ChapterBody, "", new { @class = "text-xs text-red-600" })
        </div>

        <div>
            <label class="mb-1 block text-sm font-medium">Assign Reviewer(s)</label>
            <select id="reviewerSelect" class="w-full" multiple>
                @foreach (var option in reviewerOptions)
                {
                    <option value="@option.Value" @(option.Selected ? "selected" : null)>@option.Text</option>
                }
            </select>
            <p class="mt-1 text-xs text-slate-500">Select at least one reviewer from this dropdown. Plain text entry is not allowed.</p>
        </div>

        <div>
            @Html.LabelFor(m => m.ChangeNotes, "Change Notes For Reviewers", new { @class = "mb-1 block text-sm font-medium" })
            @Html.TextAreaFor(m => m.ChangeNotes, 4, 60, new { @class = "w-full rounded-md border border-slate-300 px-3 py-2", placeholder = "Describe what changed and what reviewers should focus on." })
            @Html.ValidationMessageFor(m => m.ChangeNotes, "", new { @class = "text-xs text-red-600" })
        </div>

        <button type="submit" class="rounded bg-slate-900 px-4 py-2 text-white">Save Draft</button>
    }
    </div>
</section>

@section scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.tiny.cloud/1/zr0s1ze2y3f4ufpcb1gn892mftbi3j04oxcc3ii21s0pgaoe/tinymce/6/tinymce.min.js"
            referrerpolicy="origin"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(function () {
            $("#reviewerSelect").select2({
                width: "100%",
                placeholder: "Select reviewer(s)",
                closeOnSelect: false
            });

            tinymce.init({
                selector: "#chapterBodyEditor",
                menubar: "file edit view insert format tools table help",
                plugins: "lists link image table code fullscreen wordcount preview searchreplace visualblocks",
                toolbar: "undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | forecolor backcolor | alignleft aligncenter alignright alignjustify | bullist numlist outdent indent | link image table | tableprops tabledelete | tableinsertrowbefore tableinsertrowafter tabledeleterow | tableinsertcolbefore tableinsertcolafter tabledeletecol | removeformat code fullscreen preview",
                table_toolbar: "tableprops tabledelete | tableinsertrowbefore tableinsertrowafter tabledeleterow | tableinsertcolbefore tableinsertcolafter tabledeletecol",
                height: 420,
                content_style: "body { max-width: 760px; margin: 24px auto; font-family: Georgia, 'Times New Roman', serif; font-size: 16px; line-height: 1.6; } h1 { font-size: 2rem; } h2 { font-size: 1.6rem; } h3 { font-size: 1.3rem; }",
                branding: false,
                promotion: false,
                browser_spellcheck: true,
                convert_urls: false
            });

            $("#chapterForm").on("submit", function () {
                tinymce.triggerSave();

                var selectedReviewerIds = $("#reviewerSelect").val() || [];
                if (selectedReviewerIds.length < 1) {
                    alert("Please select at least one reviewer before saving the draft.");
                    return false;
                }

                $("#reviewerIds").val(selectedReviewerIds.join(","));
            });

            $("#chapterForm").validate({
                rules: {
                    ChapterTitle: { required: true, maxlength: 250 },
                    ChapterBody: { required: true }
                }
            });
        });
    </script>
}
