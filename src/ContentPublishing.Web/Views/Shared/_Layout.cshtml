<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Content Publishing</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-slate-100 text-slate-900">
    @{
        var currentController = (ViewContext.RouteData.Values["controller"] ?? string.Empty).ToString();
        var currentAction = (ViewContext.RouteData.Values["action"] ?? string.Empty).ToString();
    }
    <header class="bg-slate-900 text-white">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
            <h1 class="text-xl font-semibold">Content Publishing & Review Management</h1>
            <nav class="flex items-center gap-4 text-sm">
                <a class="hover:underline" href="@Url.Action("Index", "Home")">Home</a>
                <a class="hover:underline" href="@Url.Action("Published", "Content")">Published</a>
                @if (Request.IsAuthenticated)
                {
                    using (Html.BeginForm("Logout", "Account", FormMethod.Post, new { @class = "inline" }))
                    {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="rounded bg-white px-3 py-1 text-slate-900">Logout</button>
                    }
                }
                else
                {
                    <a class="hover:underline" href="@Url.Action("Login", "Account")">Login</a>
                    <a class="hover:underline" href="@Url.Action("Register", "Account")">Register</a>
                }
            </nav>
        </div>
    </header>

    @if (Request.IsAuthenticated)
    {
        <div class="mx-auto flex max-w-7xl flex-col gap-6 px-4 py-8 lg:flex-row">
            <aside class="lg:sticky lg:top-4 lg:h-fit lg:w-64 lg:shrink-0 rounded-lg bg-white p-4 shadow">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Navigation</h2>
                <nav class="mt-3 space-y-1 text-sm">
                    <a class="block rounded px-3 py-2 @(currentController == "Home" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                       href="@Url.Action("Index", "Home")">Home</a>
                          <a class="block rounded px-3 py-2 @(currentController == "Content" && currentAction == "Index" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                              href="@Url.Content("~/Content/Index")">My Content</a>
                    <a class="block rounded px-3 py-2 @(currentController == "Content" && currentAction == "Create" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                       href="@Url.Action("Create", "Content")">Create Content</a>
                    <a class="block rounded px-3 py-2 @(currentController == "Content" && currentAction == "Published" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                       href="@Url.Action("Published", "Content")">Published</a>

                    @if (User.IsInRole("Reviewer"))
                    {
                        <a class="block rounded px-3 py-2 @(currentController == "Review" && currentAction == "PendingReviews" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                           href="@Url.Action("PendingReviews", "Review")">Pending Reviews</a>
                        <a class="block rounded px-3 py-2 @(currentController == "Review" && currentAction == "ReviewHistory" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                           href="@Url.Action("ReviewHistory", "Review")">Review History</a>
                    }

                    @if (User.IsInRole("Administrator"))
                    {
                        <a class="block rounded px-3 py-2 @(currentController == "Admin" && currentAction == "Dashboard" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                           href="@Url.Action("Dashboard", "Admin")">Admin Dashboard</a>
                        <a class="block rounded px-3 py-2 @(currentController == "Admin" && currentAction == "ContentManagement" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                           href="@Url.Action("ContentManagement", "Admin")">Content Management</a>
                        <a class="block rounded px-3 py-2 @(currentController == "Admin" && currentAction == "Users" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                           href="@Url.Action("Users", "Admin")">Users</a>
                    }

                    <a class="block rounded px-3 py-2 @(currentController == "Account" && currentAction == "Profile" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100")"
                       href="@Url.Action("Profile", "Account")">Profile</a>
                </nav>
            </aside>

            <main class="min-w-0 flex-1">
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <main class="mx-auto max-w-6xl px-4 py-8">
            @RenderBody()
        </main>
    }

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script
    src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    @RenderSection("scripts", required: false)
</body>

</html>
