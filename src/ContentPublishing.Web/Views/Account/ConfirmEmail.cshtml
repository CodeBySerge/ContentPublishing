@{
    ViewBag.Title = "Email Confirmed";
}

<section class="mx-auto max-w-xl rounded-lg bg-white p-6 shadow">
    <h2 class="mb-2 text-2xl font-bold">Email Confirmed</h2>
    <p class="text-slate-700">Your account has been confirmed. You can now sign in.</p>
    <p class="mt-4">@Html.ActionLink("Go to login", "Login", "Account", null, new { @class = "font-semibold text-slate-900" })</p>
</section>
