@{
    ViewBag.Title = "Confirm your email";
}

<section class="mx-auto max-w-xl rounded-lg bg-white p-6 shadow">
    <h2 class="mb-2 text-2xl font-bold">Registration Successful</h2>
    <p class="text-slate-700">Please check your inbox and confirm your email address before signing in.</p>

    @if (TempData["RegistrationWarning"] != null)
    {
        <p class="mt-3 rounded-md border border-amber-300 bg-amber-50 px-3 py-2 text-amber-900">@TempData["RegistrationWarning"]</p>
    }
</section>
