@model ContentPublishing.Web.Models.ApplicationUser
@{
    ViewBag.Title = "Profile";
    var roleDisplay = (ViewBag.RoleDisplay as string) ?? "Unassigned";
}

<section class="mx-auto max-w-2xl rounded-lg bg-white p-6 shadow">
    <h2 class="mb-4 text-2xl font-bold">Profile</h2>
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div>
            <dt class="text-sm text-slate-500">Full Name</dt>
            <dd class="font-medium">@Model.FullName</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">Email</dt>
            <dd class="font-medium">@Model.Email</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">Description</dt>
            <dd class="font-medium">@(string.IsNullOrWhiteSpace(Model.Description) ? "Not provided" : Model.Description)
            </dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">Assigned Role</dt>
            <dd class="font-medium">@roleDisplay</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">Created</dt>
            <dd class="font-medium">@Model.CreatedDate.ToString("u")</dd>
        </div>
        <div>
            <dt class="text-sm text-slate-500">Last Login</dt>
            <dd class="font-medium">@(Model.LastLogin.HasValue ? Model.LastLogin.Value.ToString("u") : "Never")</dd>
        </div>
    </dl>
</section>
