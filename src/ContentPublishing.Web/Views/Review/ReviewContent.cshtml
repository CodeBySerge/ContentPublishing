@model ContentPublishing.Web.ViewModels.ReviewContentViewModel
@using System.Web
@{
    ViewBag.Title = "Review Content";
}

<section class="space-y-4">
    <div class="app-card p-6">
        <h2 class="text-2xl font-bold">@Html.Raw(Model.Title)</h2>
        <p class="mt-1 text-sm text-slate-500">Content Status: @Model.ContentStatus</p>
        <div class="prose mt-4 max-w-none text-slate-700">@Html.Raw(Model.Description)</div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="app-card border-red-200 bg-red-50 p-3 text-sm text-red-700" role="alert">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="app-card border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-700" role="status">
            @TempData["SuccessMessage"]</div>
        }

        <div class="app-card p-6">
            <h3 class="mb-2 text-xl font-semibold">Author Change Notes</h3>
            @if (string.IsNullOrWhiteSpace(Model.AuthorChangeNotes))
            {
                <p class="text-slate-500">No author notes were provided for this submission.</p>
            }
            else
            {
                <div class="prose max-w-none text-slate-700">@Html.Raw(Model.AuthorChangeNotes)</div>
            }
        </div>

        <div class="app-card p-6">
            <h3 class="mb-2 text-xl font-semibold">Highlighted Changes</h3>
            @if (Model.HasHighlightedChanges)
            {
                <p class="mb-3 text-sm text-slate-600">Default view shows only edited sections. Use toggle to expand full context if needed.</p>
                <div class="mb-3 flex flex-wrap gap-2">
                    <button type="button" id="showEditOnly"
                            class="rounded border border-slate-300 bg-slate-900 px-3 py-1 text-sm font-semibold text-white">Edits Only</button>
                    <button type="button" id="showFullContext"
                            class="rounded border border-slate-300 bg-white px-3 py-1 text-sm font-semibold text-slate-700">Show Full Context</button>
                </div>

                <div id="editsOnlyDiff">@Html.Raw(Model.HighlightedChangesIsolatedHtml)</div>
                <div id="fullContextDiff" class="hidden">@Html.Raw(Model.HighlightedChangesFullHtml)</div>
            }
            else
            {
                @Html.Raw(Model.HighlightedChangesIsolatedHtml)
            }
        </div>

        <div class="app-card p-6">
            <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
                <h3 class="text-xl font-semibold">Full Updated Article Preview</h3>
                <button type="button" id="toggleFullPreview"
                        class="rounded border border-slate-300 bg-white px-3 py-1 text-sm font-semibold text-slate-700">Show Full Preview</button>
            </div>
            <p class="mb-3 text-sm text-slate-600">Use this when you want to review the final article as a complete document before approval.</p>
            <div id="fullArticlePreview" class="hidden">
                @Html.Raw(Model.FullPreviewHtml)
            </div>
        </div>

        <div class="app-card p-6">
            <h3 class="mb-2 text-xl font-semibold">Chapters</h3>
            <ul class="space-y-2">
                @foreach (var ch in Model.Chapters)
                {
                    <li class="rounded border border-slate-200 p-3">
                        <p class="font-semibold">@ch.ChapterOrder. @ch.ChapterTitle</p>
                    </li>
                }
            </ul>
        </div>

        <div class="app-card p-6">
            <h3 class="mb-4 text-xl font-semibold">Decision</h3>

            @using (Html.BeginForm("RequestClarification", "Review", FormMethod.Post, new { id = "clarificationForm", @class = "mb-5 space-y-3 rounded-lg border border-amber-200 bg-amber-50 p-4" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="ContentId" value="@Model.ContentId" />
                <input type="hidden" name="ReviewId" value="@Model.ReviewId" />
                <label class="block text-sm font-medium" for="clarificationMessage">Request Clarification From Author</label>
                <textarea id="clarificationMessage" name="Message"
                          class="app-form-field w-full rounded-lg border border-amber-300 px-3 py-2" rows="3"
                          placeholder="Ask the author for clarification before making an approve/reject decision."></textarea>
                <button type="submit" class="rounded-lg border border-amber-500 bg-white px-4 py-2 text-sm font-semibold text-amber-700 hover:bg-amber-100">Send Clarification Request</button>
            }

            @using (Html.BeginForm("Approve", "Review", FormMethod.Post, new { id = "approveForm", @class = "space-y-3" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="ContentId" value="@Model.ContentId" />
                <input type="hidden" name="ReviewId" value="@Model.ReviewId" />
                <label class="block text-sm font-medium" for="approveComments">Approval comments (optional)</label>
                <textarea id="approveComments" name="Comments"
                          class="app-form-field w-full rounded-lg border border-slate-300 px-3 py-2" rows="4"
                          aria-label="Approval comments"></textarea>
                <div class="flex flex-wrap gap-3">
                    <button type="submit" class="app-btn-accent rounded-lg px-4 py-2 text-sm font-semibold text-white">Approve
                        Draft</button>
                        <button type="button" id="openRejectModal"
                                class="rounded-lg border border-red-300 bg-white px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50">Reject
                            Draft</button>
                        </div>
                    }

                    <div id="rejectModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/50 p-4"
                         role="dialog" aria-modal="true" aria-labelledby="rejectModalTitle">
                        <div class="app-card w-full max-w-lg p-5">
                            <h4 id="rejectModalTitle" class="text-lg font-semibold">Reject Draft</h4>
                            <p class="mt-1 text-sm text-slate-600">Provide rejection notes so the author can revise effectively.</p>

                            @using (Html.BeginForm("Reject", "Review", FormMethod.Post, new { id = "rejectForm", @class = "mt-4 space-y-3" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ContentId" value="@Model.ContentId" />
                                <input type="hidden" name="ReviewId" value="@Model.ReviewId" />
                                <label class="block text-sm font-medium" for="rejectComments">Rejection notes</label>
                                <textarea id="rejectComments" name="Comments"
                                          class="app-form-field w-full rounded-lg border border-slate-300 px-3 py-2" rows="5" required
                                          aria-required="true"></textarea>
                                <div class="flex justify-end gap-2">
                                    <button type="button" id="cancelRejectModal"
                                            class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Cancel</button>
                                    <button type="submit"
                                            class="rounded-lg bg-red-700 px-4 py-2 text-sm font-semibold text-white">Confirm
                                        Rejection</button>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </section>

                @section scripts {
                    <script>
                        $(function () {
                            var $rejectModal = $("#rejectModal");

                            $("#openRejectModal").on("click", function () {
                                $rejectModal.removeClass("hidden").addClass("flex");
                                $("#rejectComments").trigger("focus");
                            });

                            $("#cancelRejectModal").on("click", function () {
                                $rejectModal.addClass("hidden").removeClass("flex");
                            });

                            $rejectModal.on("click", function (e) {
                                if (e.target === this) {
                                    $rejectModal.addClass("hidden").removeClass("flex");
                                }
                            });

                            $("#rejectForm").validate({
                                rules: { Comments: { required: true, minlength: 5 } },
                                messages: { Comments: "Rejection comments are required (minimum 5 chars)." }
                            });

                            $("#clarificationForm").validate({
                                rules: { Message: { required: true, minlength: 5 } },
                                messages: { Message: "Clarification request requires at least 5 characters." }
                            });

                            $("#showEditOnly").on("click", function () {
                                $("#editsOnlyDiff").removeClass("hidden");
                                $("#fullContextDiff").addClass("hidden");
                                $(this).removeClass("bg-white text-slate-700").addClass("bg-slate-900 text-white");
                                $("#showFullContext").removeClass("bg-slate-900 text-white").addClass("bg-white text-slate-700");
                            });

                            $("#showFullContext").on("click", function () {
                                $("#fullContextDiff").removeClass("hidden");
                                $("#editsOnlyDiff").addClass("hidden");
                                $(this).removeClass("bg-white text-slate-700").addClass("bg-slate-900 text-white");
                                $("#showEditOnly").removeClass("bg-slate-900 text-white").addClass("bg-white text-slate-700");
                            });

                            $("#toggleFullPreview").on("click", function () {
                                var $preview = $("#fullArticlePreview");
                                var isHidden = $preview.hasClass("hidden");
                                if (isHidden) {
                                    $preview.removeClass("hidden");
                                    $(this).text("Hide Full Preview");
                                } else {
                                    $preview.addClass("hidden");
                                    $(this).text("Show Full Preview");
                                }
                            });

                            @if (TempData["SuccessMessage"] != null)
                                {
                                    <text>window.appToast("success", "@HttpUtility.JavaScriptStringEncode((string)TempData["SuccessMessage"])");</text>
                            }
                                @if (TempData["ErrorMessage"] != null)
                                {
                                    <text>window.appToast("error", "@HttpUtility.JavaScriptStringEncode((string)TempData["ErrorMessage"])");</text>
                            }
                            });
                    </script>
                }
