@model ContentPublishing.Web.ViewModels.ReviewContentViewModel
@{
    ViewBag.Title = "Review Content";
}

<section class="space-y-4">
    <div class="rounded-lg bg-white p-6 shadow">
        <h2 class="text-2xl font-bold">@Model.Title</h2>
        <p class="mt-1 text-sm text-slate-500">Content Status: @Model.ContentStatus</p>
        <p class="mt-4 whitespace-pre-line text-slate-700">@Model.Description</p>
    </div>

    <div class="rounded-lg bg-white p-6 shadow">
        <h3 class="mb-2 text-xl font-semibold">Chapters</h3>
        <ul class="space-y-2">
            @foreach (var ch in Model.Chapters)
            {
                <li class="rounded border border-slate-200 p-3">
                    <p class="font-semibold">@ch.ChapterOrder. @ch.ChapterTitle</p>
                </li>
            }
        </ul>
    </div>

    <div class="rounded-lg bg-white p-6 shadow">
        <h3 class="mb-4 text-xl font-semibold">Decision</h3>

        <div class="grid gap-4 md:grid-cols-2">
            @using (Html.BeginForm("Approve", "Review", FormMethod.Post, new { id = "approveForm", @class = "space-y-3" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="ContentId" value="@Model.ContentId" />
                <input type="hidden" name="ReviewId" value="@Model.ReviewId" />
                <label class="block text-sm font-medium">Approval comments</label>
                <textarea name="Comments" class="w-full rounded border border-slate-300 px-3 py-2" rows="5"></textarea>
                <button type="submit" class="rounded bg-emerald-700 px-4 py-2 text-white">Approve</button>
            }

            @using (Html.BeginForm("Reject", "Review", FormMethod.Post, new { id = "rejectForm", @class = "space-y-3" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="ContentId" value="@Model.ContentId" />
                <input type="hidden" name="ReviewId" value="@Model.ReviewId" />
                <label class="block text-sm font-medium">Rejection comments</label>
                <textarea id="rejectComments" name="Comments" class="w-full rounded border border-slate-300 px-3 py-2" rows="5" required></textarea>
                <button type="submit" class="rounded bg-red-700 px-4 py-2 text-white">Reject</button>
            }
        </div>
    </div>
</section>

@section scripts {
<script>
$(function () {
    $("#rejectForm").validate({
        rules: { Comments: { required: true, minlength: 5 } },
        messages: { Comments: "Rejection comments are required (minimum 5 chars)." }
    });
});
</script>
}
