@model IList<ContentPublishing.Web.ViewModels.AuditLogListItemViewModel>
@{
    ViewBag.Title = "Audit Log";
}

<section class="space-y-4">
    <h2 class="text-2xl font-bold">Audit Log</h2>

    <div class="overflow-x-auto rounded-lg bg-white shadow">
        <table class="min-w-full text-xs">
            <thead class="bg-slate-100 text-left text-slate-600">
                <tr>
                    <th class="px-3 py-2">Timestamp</th>
                    <th class="px-3 py-2">User</th>
                    <th class="px-3 py-2">Action</th>
                    <th class="px-3 py-2">Entity</th>
                    <th class="px-3 py-2">EntityId</th>
                    <th class="px-3 py-2">Old</th>
                    <th class="px-3 py-2">New</th>
                    <th class="px-3 py-2">IP</th>
                    <th class="px-3 py-2">Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr class="border-t border-slate-100">
                        <td class="px-3 py-2">@log.Timestamp.ToString("u")</td>
                        <td class="px-3 py-2">@log.UserId</td>
                        <td class="px-3 py-2">@log.Action</td>
                        <td class="px-3 py-2">@log.EntityType</td>
                        <td class="px-3 py-2">@log.EntityId</td>
                        <td class="px-3 py-2">@log.OldValue</td>
                        <td class="px-3 py-2">@log.NewValue</td>
                        <td class="px-3 py-2">@log.IpAddress</td>
                        <td class="px-3 py-2">@log.ChangeDetails</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
