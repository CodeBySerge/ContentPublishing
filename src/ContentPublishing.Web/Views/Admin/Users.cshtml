@model IList<ContentPublishing.Web.ViewModels.UserListItemViewModel>
@using System.Linq
@using System.Web
@{
    ViewBag.Title = "Users";
}

<section class="space-y-6">
    <div class="app-card p-6">
        <h2 class="text-2xl font-bold text-slate-900">User Management</h2>
        <p class="mt-1 text-sm text-slate-600">Assign and maintain roles with clear, searchable user cards.</p>

        <div class="mt-4 grid gap-3 md:grid-cols-2">
            <label class="block text-sm font-medium text-slate-700">
                Search users
                <input id="userSearch" type="search"
                       class="app-form-field mt-1 w-full rounded-lg border border-slate-300 px-3 py-2"
                       placeholder="Search by name or email" aria-label="Search users by name or email" />
            </label>
            <label class="block text-sm font-medium text-slate-700">
                Filter by role
                <select id="roleFilter" class="app-form-field mt-1 w-full rounded-lg border border-slate-300 px-3 py-2"
                        aria-label="Filter users by role">
                    <option value="all">All roles</option>
                    <option value="author">Author</option>
                    <option value="reviewer">Reviewer</option>
                    <option value="admin">Admin</option>
                </select>
            </label>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="app-card border-red-200 bg-red-50 p-3 text-sm text-red-700" role="alert">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="app-card border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-700" role="status">
            @TempData["SuccessMessage"]</div>
        }

        <div id="usersGrid" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            @foreach (var user in Model.OrderBy(u => u.FullName).ThenBy(u => u.Email))
            {
                var fullName = string.IsNullOrWhiteSpace(user.FullName) ? "Unnamed" : user.FullName;
                var initials = string.Join(string.Empty, fullName.Split(' ').Where(p => !string.IsNullOrWhiteSpace(p)).Select(p
            => p.Substring(0, 1)).Take(2)).ToUpperInvariant();
                var roleText = string.IsNullOrWhiteSpace(user.AssignedRoleName) ? "Unassigned" : (user.AssignedRoleName ==
           "Administrator" ? "Admin" : user.AssignedRoleName);
                var roleData = roleText.ToLowerInvariant();

                <article class="app-card user-card p-4" data-name="@fullName.ToLowerInvariant()"
                         data-email="@user.Email.ToLowerInvariant()" data-role="@roleData" aria-label="User card for @fullName">
                    <div class="flex items-start gap-3">
                        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-blue-100 font-semibold text-blue-700"
                             aria-hidden="true">@(!string.IsNullOrWhiteSpace(initials) ? initials : "U")</div>
                        <div class="min-w-0 flex-1">
                            <h3 class="truncate text-lg font-semibold text-slate-900">@fullName</h3>
                            <p class="truncate text-sm text-slate-600">@user.Email</p>
                            <p class="mt-1 text-xs text-slate-500">@(string.IsNullOrWhiteSpace(user.Description) ? "No profile description" : user.Description)</p>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center justify-between rounded-lg bg-slate-50 px-3 py-2">
                        <span class="text-xs uppercase tracking-wide text-slate-500">Current role</span>
                        <span class="rounded-full bg-slate-200 px-2 py-1 text-xs font-semibold text-slate-700">@roleText</span>
                    </div>

                    @using (Html.BeginForm("AssignRole", "Admin", FormMethod.Post, new { @class = "mt-3 space-y-2 role-form" }))
                    {
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="userId" value="@user.UserId" />
                        <label class="block text-sm font-medium text-slate-700">
                            Assign role
                            <select name="roleName" class="app-form-field mt-1 w-full rounded-lg border border-slate-300 px-3 py-2"
                                    aria-label="Assign role for @fullName">
                                <option value="Author" @(roleText == "Author" ? "selected" : null)>Author</option>
                                <option value="Reviewer" @(roleText == "Reviewer" ? "selected" : null)>Reviewer</option>
                                <option value="Administrator" @(roleText == "Admin" ? "selected" : null)>Admin</option>
                            </select>
                        </label>
                        <button type="submit" class="app-btn-primary w-full rounded-lg px-3 py-2 text-sm font-semibold">Save
                            Role</button>
                        }
                    </article>
                }
            </div>

            <p id="noUsersFound"
               class="hidden rounded-lg border border-dashed border-slate-300 bg-white p-4 text-sm text-slate-500">No users
                match the selected filters.</p>
            </section>

            @section scripts {
                <script>
                    $(function () {
                        var $cards = $(".user-card");
                        var $search = $("#userSearch");
                        var $roleFilter = $("#roleFilter");
                        var $noUsersFound = $("#noUsersFound");

                        function applyFilters() {
                            var q = ($search.val() || "").toString().toLowerCase().trim();
                            var role = ($roleFilter.val() || "all").toString().toLowerCase();
                            var visibleCount = 0;

                            $cards.each(function () {
                                var $card = $(this);
                                var text = ($card.data("name") + " " + $card.data("email")).toLowerCase();
                                var cardRole = ($card.data("role") || "").toString().toLowerCase();
                                var matchesQuery = !q || text.indexOf(q) >= 0;
                                var matchesRole = role === "all" || cardRole.indexOf(role) >= 0;
                                var show = matchesQuery && matchesRole;

                                $card.toggle(show);
                                if (show) {
                                    visibleCount += 1;
                                }
                            });

                            $noUsersFound.toggleClass("hidden", visibleCount > 0);
                        }

                        $search.on("input", applyFilters);
                        $roleFilter.on("change", applyFilters);

                        $(".role-form").on("submit", function (e) {
                            var selectedRole = $(this).find("select[name='roleName'] option:selected").text();
                            if (!confirm("Change role to " + selectedRole + "?")) {
                                e.preventDefault();
                            }
                        });

                        @if (TempData["SuccessMessage"] != null)
                            {
                                <text>window.appToast("success", "@HttpUtility.JavaScriptStringEncode((string)TempData["SuccessMessage"]) ");</text>
                        }
                            @if (TempData["ErrorMessage"] != null)
                            {
                                <text>window.appToast("error", "@HttpUtility.JavaScriptStringEncode((string)TempData["ErrorMessage"]) ");</text>
                        }
                        });
                </script>
            }
