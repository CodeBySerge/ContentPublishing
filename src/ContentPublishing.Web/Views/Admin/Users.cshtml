@model IList<ContentPublishing.Web.ViewModels.UserListItemViewModel>
@{
    ViewBag.Title = "Users";
}

<section class="space-y-4">
    <h2 class="text-2xl font-bold">User Management</h2>

    <div class="overflow-hidden rounded-lg bg-white shadow">
        <table class="min-w-full text-sm">
            <thead class="bg-slate-100 text-left text-slate-600">
                <tr>
                    <th class="px-4 py-3">Name</th>
                    <th class="px-4 py-3">Email</th>
                    <th class="px-4 py-3">Active</th>
                    <th class="px-4 py-3">Roles</th>
                    <th class="px-4 py-3">Assign Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr class="border-t border-slate-100">
                        <td class="px-4 py-3">@user.FullName</td>
                        <td class="px-4 py-3">@user.Email</td>
                        <td class="px-4 py-3">@user.IsActive</td>
                        <td class="px-4 py-3">@string.Join(", ", user.Roles)</td>
                        <td class="px-4 py-3">
                            @using (Html.BeginForm("AssignRole", "Admin", FormMethod.Post, new { @class = "flex gap-2" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <select name="roleName" class="rounded border border-slate-300 px-2 py-1">
                                    <option value="Author">Author</option>
                                    <option value="Reviewer">Reviewer</option>
                                    <option value="Administrator">Administrator</option>
                                </select>
                                <button type="submit" class="rounded bg-slate-900 px-3 py-1 text-white">Save</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
