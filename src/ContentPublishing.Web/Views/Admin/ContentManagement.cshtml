@model IList<ContentPublishing.Web.ViewModels.AdminContentListItemViewModel>
@using System.Collections.Generic
@using System.Web.Mvc
@{
    ViewBag.Title = "Content Management";
    var reviewerOptions = ViewBag.ReviewerOptions as IList<SelectListItem> ?? new List<SelectListItem>();
}

<section class="space-y-4">
    <h2 class="text-2xl font-bold">Content Management</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded border border-red-200 bg-red-50 p-3 text-sm text-red-700">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="rounded border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-700">@TempData["SuccessMessage"]</div>
    }

    <div class="overflow-hidden rounded-lg bg-white shadow">
        <table class="min-w-full text-sm">
            <thead class="bg-slate-100 text-left text-slate-600">
                <tr>
                    <th class="px-4 py-3">Title</th>
                    <th class="px-4 py-3">Author</th>
                    <th class="px-4 py-3">Status</th>
                    <th class="px-4 py-3">Scheduled</th>
                    <th class="px-4 py-3">Assigned</th>
                    <th class="px-4 py-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="border-t border-slate-100 align-top">
                        <td class="px-4 py-3">@item.Title</td>
                        <td class="px-4 py-3">@item.AuthorName</td>
                        <td class="px-4 py-3">@item.Status</td>
                        <td class="px-4 py-3">@(item.ScheduledPublishDate.HasValue ? item.ScheduledPublishDate.Value.ToString("u") : "-")</td>
                        <td class="px-4 py-3">@item.AssignedReviewerCount</td>
                        <td class="px-4 py-3">
                            <div class="flex flex-wrap gap-2">
                                @using (Html.BeginForm("Publish", "Admin", FormMethod.Post, new { @class = "flex flex-wrap items-center gap-2" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ContentId" />
                                    <input type="datetime-local" name="scheduledPublishDateUtc" class="rounded border border-slate-300 px-2 py-1" />
                                    <button type="submit" class="rounded bg-indigo-700 px-3 py-1 text-white">Publish</button>
                                }

                                @using (Html.BeginForm("AssignReviewer", "Admin", FormMethod.Post, new { @class = "flex gap-2" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="ContentId" value="@item.ContentId" />
                                    <select name="ReviewerId" class="rounded border border-slate-300 px-2 py-1">
                                        @foreach (var reviewer in reviewerOptions)
                                        {
                                            <option value="@reviewer.Value">@reviewer.Text</option>
                                        }
                                    </select>
                                    <button type="submit" class="rounded border border-slate-300 px-3 py-1">Assign</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
