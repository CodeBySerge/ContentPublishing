@model ContentPublishing.Web.Net8.Models.ChapterEditViewModel
@{
    ViewData["Title"] = "Edit Chapter";
}

<section class="space-y-6">
    <div class="app-card section-card" style="max-width: 920px; margin: 0 auto;">
        <h2>Edit Chapter</h2>
        <form asp-action="Edit" method="post" class="mt-3 space-y-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ChapterId" />
            <input type="hidden" asp-for="ContentId" />

            <div>
                <label asp-for="ChapterTitle" class="form-label"></label>
                <input asp-for="ChapterTitle" class="form-control" maxlength="250" />
                <span asp-validation-for="ChapterTitle" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="ChapterBody" class="form-label"></label>
                <textarea asp-for="ChapterBody" class="form-control" rows="14"></textarea>
                <span asp-validation-for="ChapterBody" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="ChangeNotes" class="form-label">Change Notes (optional)</label>
                <textarea asp-for="ChangeNotes" class="form-control" rows="3"></textarea>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-primary">Save Draft</button>
                <a class="quick-link" asp-controller="Content" asp-action="Details" asp-route-id="@Model.ContentId">Back</a>
            </div>
        </form>

        <form asp-controller="Chapter" asp-action="SubmitForReview" method="post" class="mt-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="contentId" value="@Model.ContentId" />
            <button type="submit" class="btn btn-success">Submit For Review</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}