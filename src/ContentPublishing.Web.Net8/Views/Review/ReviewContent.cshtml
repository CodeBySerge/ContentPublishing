@model ContentPublishing.Web.Net8.Models.ReviewContentViewModel
@{
    ViewData["Title"] = "Review Content";
}

<section class="space-y-6">
    <div class="app-card section-card">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h2 class="m-0">@Model.Title</h2>
            <span class="badge text-bg-warning">@Model.ContentStatus</span>
        </div>
        <p class="mt-3 mb-2">@Model.Description</p>
        <p class="text-muted small mb-0">Updated: @Model.LastModifiedDate.ToString("u")</p>
    </div>

    <div class="app-card section-card">
        @if (TempData["ErrorMessage"] is string error && !string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-warning" role="alert">@error</div>
        }
        @if (TempData["SuccessMessage"] is string success && !string.IsNullOrWhiteSpace(success))
        {
            <div class="alert alert-success" role="status">@success</div>
        }

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h3 class="m-0">Chapters</h3>
            <a class="quick-link" asp-controller="Review" asp-action="PendingReviews">Back to Pending Reviews</a>
        </div>

        @if (!Model.Chapters.Any())
        {
            <p class="mt-3 mb-0 text-muted">No chapters found for this content item.</p>
        }
        else
        {
            <div class="mt-3 space-y-3">
                @foreach (var chapter in Model.Chapters)
                {
                    <article class="rounded border border-slate-200 p-3">
                        <h4 class="h6 mb-2">@chapter.ChapterOrder. @chapter.ChapterTitle</h4>
                        <div class="text-muted">@chapter.ChapterBody</div>
                    </article>
                }
            </div>
        }
    </div>

    <div class="app-card section-card">
        <h3>Decision</h3>
        <p class="text-muted">Approve to move content to Admin publishing queue, or reject to return to Draft.</p>
        <div class="d-flex gap-2 mt-3">
            <form asp-controller="Review" asp-action="Approve" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ContentId" value="@Model.ContentId" />
                <button type="submit" class="btn btn-success">Approve</button>
            </form>
            <form asp-controller="Review" asp-action="Reject" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ContentId" value="@Model.ContentId" />
                <button type="submit" class="btn btn-danger">Reject</button>
            </form>
        </div>
    </div>
</section>