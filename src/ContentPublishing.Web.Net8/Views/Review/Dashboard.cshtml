@model ContentPublishing.Web.Net8.Models.ReviewerDashboardViewModel
@{
    ViewData["Title"] = "Reviewer Dashboard";
}

<section class="space-y-6">
    <div class="app-card section-card">
        <h2>Reviewer Dashboard</h2>
        <p class="text-muted mb-0">Role-restricted migration slice for review workload visibility.</p>
        <div class="mt-3 d-flex gap-2">
            <a class="quick-link" asp-controller="Review" asp-action="PendingReviews">Pending Reviews</a>
            <a class="quick-link" asp-controller="Content" asp-action="Published">Published Content</a>
        </div>
    </div>

    <div class="content-grid">
        <article class="app-card section-card"><h3>Under Review</h3><p class="mb-0">@Model.UnderReviewCount</p></article>
        <article class="app-card section-card"><h3>Published</h3><p class="mb-0">@Model.PublishedCount</p></article>
    </div>

    <div class="app-card section-card">
        <h3>Next Review Candidates</h3>
        @if (!Model.NextReviewCandidates.Any())
        {
            <p class="text-muted mb-0">No content currently under review.</p>
        }
        else
        {
            <ul class="mb-0 mt-2">
                @foreach (var item in Model.NextReviewCandidates)
                {
                    <li>
                        <a asp-controller="Review" asp-action="ReviewContent" asp-route-contentId="@item.ContentId">@item.Title</a>
                        <span class="text-muted">(@item.LastModifiedDate.ToString("u"))</span>
                    </li>
                }
            </ul>
        }
    </div>
</section>